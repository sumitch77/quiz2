<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>List</title>
    <style>
:root {
  --primary: #00e5ff;
  --primary-hover: #00b8d4;
  --primary-green: #00e676;
  --text-dark: #e0f7fa;
  --text-muted: #78909c;
  --accent-red: #ff1744;
  --bg-page: #0d1117;
  --bg-card: #161b22;
  --bg-nav: #0d1117;
  --border: rgba(0, 229, 255, 0.1);
  --border-hover: rgba(0, 229, 255, 0.3);
}

* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

body {
  background-color: var(--bg-page);
  color: var(--text-dark);
  font-family: 'Segoe UI', Arial, sans-serif;
  min-height: 100vh;
  padding: 32px 24px;
}

h1 {
  font-size: 1.6rem;
  color: var(--primary);
  margin-bottom: 16px;
  letter-spacing: 0.5px;
}

/* Message div — accent red only */
#message {
  color: var(--accent-red);
  font-size: 0.9rem;
  min-height: 20px;
  margin-bottom: 16px;
  font-weight: 500;
}

/* Inputs */
#username,
#fileInput {
  display: inline-block;
  background-color: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 6px;
  color: var(--text-dark);
  font-size: 0.9rem;
  padding: 8px 12px;
  margin-right: 10px;
  margin-bottom: 12px;
  outline: none;
  transition: border-color 0.2s;
}

#username::placeholder {
  color: var(--text-muted);
}

#username:focus,
#fileInput:focus {
  border-color: var(--border-hover);
}

/* Upload button */
#upload {
  display: inline-block;
  padding: 8px 20px;
  background-color: var(--primary);
  color: var(--bg-page);
  border: none;
  border-radius: 6px;
  font-size: 0.9rem;
  font-weight: 600;
  cursor: pointer;
  margin-bottom: 24px;
  transition: background-color 0.2s;
}

#upload:hover {
  background-color: var(--primary-hover);
}

/* Docs list */
#docs {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.lb-info {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 12px 16px;
  background-color: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 8px;
  transition: border-color 0.2s;
}

.lb-info:hover {
  border-color: var(--border-hover);
}

.lb-name {
  font-weight: 600;
  font-size: 0.9rem;
  color: var(--primary);
  min-width: 120px;
  white-space: nowrap;
}

/* Link + download on the same line */
.lb-link-row {
  display: flex;
  align-items: center;
  gap: 12px;
  flex: 1;
  overflow: hidden;
}

a.lb-link {
  font-size: 0.85rem;
  color: #0000FF;
  text-decoration: none;
  word-break: break-all;
  flex: 1;
  transition: color 0.2s;
}

a.lb-link:hover {
  color: var(--text-dark);
  text-decoration: underline;
}

/* Download button */
a.lb-download {
  display: inline-block;
  padding: 4px 14px;
  background-color: transparent;
  color: var(--primary-green);
  border: 1px solid var(--primary-green);
  border-radius: 5px;
  font-size: 0.8rem;
  font-weight: 600;
  text-decoration: none;
  white-space: nowrap;
  transition: background-color 0.2s, color 0.2s;
}

a.lb-download:hover {
  background-color: var(--primary-green);
  color: var(--bg-page);
}
    </style>
</head>
<body>
   <h1>All Files</h1>
<div id="message"></div>
<input type="text" id="username" placeholder="Enter file name" />
<input type="file" name="filesend" id="fileInput" />
<button id="upload">Upload</button>
<div id="docs">
  <% docs.forEach(docss => { %>
    <div class="lb-info">
      <span class="lb-name"><%= docss.createdBy %></span>
      <div class="lb-link-row">
        <a class="lb-link" href="<%= docss.link %>" target="_blank" rel="noopener noreferrer">
          <%= docss.link %>
        </a>
        <a class="lb-download" href="<%= docss.link %>" download>Download</a>
      </div>
    </div>
  <% }); %>
</div>
  

       <script src="/list.js"></script>
</body>
</html>