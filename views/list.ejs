<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>List</title>
</head>
<body>
    <h1>List of Questions</h1>
    <% questions.forEach((q) => { %>
        <div>
            <p><strong>Question:</strong> <%= q.q1 %></p>
            <p><strong>Options:</strong></p>
            <ul>
                <li>A: <%= q.q2 %></li>
                <li>B: <%= q.q3 %></li>
                <li>C: <%= q.q4 %></li>
                <li>D: <%= q.q5 %></li>
            </ul>
        </div>
        <hr>
    <% }); %>
</body>
</html>