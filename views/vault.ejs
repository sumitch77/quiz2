<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <div id="warn"></div>
<nav>
  <div class="nav-left">
    <a class="nav-logo" href="/">Document<span>Site</span></a>
  </div>
  <div class="nav-right">
    <button id="edit"><input type="file" id="fileInput" accept="image/*" style="display: none;">Upload document</button>
    <button id="cut">X</button>
    <div class="menu-wrap" id="menuWrap">
      <div class="dropdown">

        <div id="imgin"></div>
      </div>
    </div>
  </div>
</nav>

<div class="hero">
  <p>
      All our documents

  </p>
</div>


<div class="quiz-container">
  <% if (quizzes.length === 0) { %>
    <p class="no-quiz">No quizzes yet. Be the first to create one!</p>
  <% } else { %>
    <% quizzes.forEach(quiz => { %>
      <div class="quiz-card">
        <div class="quiz-card-top">
          <div class="avatar"><%= quiz.createdBy.charAt(0).toUpperCase() %></div>
          <div class="quiz-info">
            <h3><%= quiz.createdBy %></h3>
            <a href="/quiz/<%= quiz._id %>/leaderboard"><button class="leaderboard">Leaderboard</button></a>
            <br>
            <span class="date"><%= quiz.createdAt.toDateString() %></span>
          </div>
        </div>
        <div class="quiz-card-bottom">
          <span class="qcount"><%= quiz.questions.length %> Questions</span>
          <a href="/quiz/<%= quiz._id %>"><button class="play-btn">Play</button></a>
        </div>
      </div>
    <% }) %>
  <% } %>
</div>


<script>
    const upload = document.getElementById('edit');
    const fileInput = document.getElementById('fileInput');

       
fileInput.addEventListener('change', function () {
    const file = this.files[0];
    if (!file) return;
 
    const reader = new FileReader();
    reader.onload = function (e) {
    //hi
    };
    reader.readAsDataURL(file);
  });

    upload.addEventListener('click', () => {
        //c
    });
</script>
</body>
</html>